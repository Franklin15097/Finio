# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=finio
DB_USER=finio_user
DB_PASSWORD=strong_password

# FastAPI
APP_NAME="Finio"
APP_ENV=production
APP_DEBUG=false
SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Telegram Bot
TELEGRAM_BOT_TOKEN=your:telegram_bot_token_here
TELEGRAM_WEBHOOK_URL=https://your-domain.com/bot-webhook
TELEGRAM_ADMIN_IDS=123456789,987654321

# Redis (если нужен для кэша/сессий)
REDIS_HOST=localhost
REDIS_PORT=6379

# Настройки логирования
LOG_LEVEL=INFO
LOG_FILE=/var/log/finio/app.log